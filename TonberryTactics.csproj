<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.5.5</Version>
    <AssemblyVersion>0.5.5.0</AssemblyVersion>
    <FileVersion>0.5.5.0</FileVersion>
    <Authors>LastOnionKnight</Authors>
    <Description>Tonberry Tactics — companion web app for the in-game plugin. AskMrRobot-style hybrid gear optimizer for FFXIV. Pure-Math by default, Balance-preset toggle, exports plans back to the plugin via GG-PLAN:v1: strings. v0.5.5 ("Brand Convergence") drops in the first round of Refia mascot artwork from Claude Design and the new circle-logo wordmark, retiring the text-only header. Plugin (formerly "GearGoblin") and web are now branded as one product. Round-trip wire-format prefixes (GG-EXPORT:v1:, GG-PLAN:v1:) stay as versioned identifiers — they're not brand names.</Description>
    <RepositoryUrl>https://github.com/LastOnionKnight/TonberryTactics</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
