<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.6.5.3</Version>
    <AssemblyVersion>0.6.5.3</AssemblyVersion>
    <FileVersion>0.6.5.3</FileVersion>
    <Authors>LastOnionKnight</Authors>
    <Description>Tonberry Tactics web companion — Blazor WASM single-page app deployed to Cloudflare Pages, consumes GG-EXPORT:v1: strings from the GearGoblin plugin, runs three-column Gear Division layout (Inventory / Best-in-Slot / Meld Audit) per-job, emits GG-PLAN:v1: strings for round-trip import. v0.6.5.3 is a version-only lockstep bump pairing with the plugin's "Collision Fix" hotfix that corrects the character-panel ghost-text bug v0.6.5.2 misdiagnosed. No functional changes to the web app; in-page version strings updated to v0.6.5.3 to keep the displayed pair version honest with the plugin.</Description>
    <RepositoryUrl>https://github.com/LastOnionKnight/TonberryTactics</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
