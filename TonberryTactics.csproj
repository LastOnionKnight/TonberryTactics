<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.6.3</Version>
    <AssemblyVersion>0.6.3.0</AssemblyVersion>
    <FileVersion>0.6.3.0</FileVersion>
    <Authors>LastOnionKnight</Authors>
    <Description>Tonberry Tactics — companion web app for the in-game plugin. v0.6.3 ("Lockstep") wires up GearGoblin.Core as a shared library so the web and plugin share their stat-priority tables, materia-tier values, and BaseParam name canonicalization. The Materia Advisor now produces real per-job recommendations for all 21 combat jobs (plus BLU) instead of falling back to GNB priority for everyone-not-Gunbreaker. Priorities sourced from public BiS guides at thebalanceffxiv.com. Wire format unchanged. Ships in lockstep with GearGoblin.Core v0.6.3 and plugin v0.6.3.</Description>
    <RepositoryUrl>https://github.com/LastOnionKnight/TonberryTactics</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
  </ItemGroup>

  <!--
    v0.6.3: ProjectReference to the shared GearGoblin.Core library.
    Path assumes the standard sibling-of-grandparent layout:

        D:\GearGoblin-Core-v0.1\GearGoblin.Core\        (Core, this reference's target)
        D:\TonberryTactics-workspace\TonberryTactics\   (this project)
        D:\GearGoblin-v0.1\GearGoblin\                  (plugin, mirrors this same reference)

    If Core lives somewhere else on your machine, update the path to
    point at your local clone. The plugin's csproj uses the same
    relative pattern (..\..\GearGoblin-Core-v0.1\GearGoblin.Core\GearGoblin.Core.csproj)
    so both halves resolve to the same library on disk.
  -->
  <ItemGroup>
    <ProjectReference Include="..\..\GearGoblin-Core-v0.1\GearGoblin.Core\GearGoblin.Core.csproj" />
  </ItemGroup>

</Project>
