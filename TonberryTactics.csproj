<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.5.4</Version>
    <AssemblyVersion>0.5.4.0</AssemblyVersion>
    <FileVersion>0.5.4.0</FileVersion>
    <Authors>LastOnionKnight</Authors>
    <Description>Tonberry Tactics — web companion to GearGoblin. AskMrRobot-style hybrid gear optimizer for FFXIV. Pure-Math by default, Balance-preset toggle, exports plans back to the in-game plugin via GG-PLAN:v1: strings. v0.5.4 ("Feedback Loop") adds a Feedback panel — pre-filled GitHub issue URL + clipboard fallback for Discord/DM, with browser/version diagnostic auto-attached — closing the beta-reporting loop with the in-game plugin's matching tab. Compatible with GearGoblin v0.4.5+ (full CPR coexistence) and the v0.4.7 round-trip /goblinimport command.</Description>
    <RepositoryUrl>https://github.com/LastOnionKnight/TonberryTactics</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
