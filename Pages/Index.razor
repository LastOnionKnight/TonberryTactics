@code {
    // ═════════════════════════════════════════════════════════════════
    //  CONSTANTS — version-locked with the plugin (v0.5.5 alignment)
    // ═════════════════════════════════════════════════════════════════
    private const string EmitterVersion = "1.1.3";
    private const string TtVersion      = "1.1.3";

    // ═════════════════════════════════════════════════════════════════
    //  INPUT / OUTPUT + PIPELINE STATE
    // ═════════════════════════════════════════════════════════════════
    private string ExportString          = "";
    private string GeneratedImportString = "";

    private ExportPayloadV1?          ParsedPayload;
    private OptimizerResult? Optimization;
    private string?                   ParseError;

    private string OptimizerMode = "Pure-Math";
    private string? ActiveJobOverride;

    // ═════════════════════════════════════════════════════════════════
    //  PORTRAIT STATE MACHINE — maps to design's pipeline state-tag
    // ═════════════════════════════════════════════════════════════════
    private enum PortraitState { Ready, Combat, Danger }
    private PortraitState Portrait = PortraitState.Ready;

    private string PipelineTagLabel() => Portrait switch
    {
        PortraitState.Combat => "ENGAGED",
        PortraitState.Danger => "WARNING",
        _                    => "AWAITING",
    };
    private string PipelineTagClass() => Portrait switch
    {
        PortraitState.Combat => "engaged",
        PortraitState.Danger => "warning",
        _                    => "",
    };

    // ═════════════════════════════════════════════════════════════════
    //  OPTIMIZER PIPELINE — unchanged from v0.5.5
    // ═════════════════════════════════════════════════════════════════
    private void RunOptimization()
    {
        if (string.IsNullOrWhiteSpace(ExportString)) return;

        ParsedPayload         = null;
        Optimization          = null;
        ParseError            = null;
        GeneratedImportString = "";

        var parseResult = GearsetParser.TryParse(ExportString);
        if (!parseResult.Success || parseResult.Payload is null)
        {
            ParseError = parseResult.Error ?? "Unknown parse error.";
            Portrait   = PortraitState.Danger;
            return;
        }
        ParsedPayload = parseResult.Payload;

        Optimization = MeldOptimizerAdapter.Optimize(ParsedPayload);

        GeneratedImportString = PlanSerializer.Serialize(
            Optimization, ParsedPayload, EmitterVersion);

        Portrait = PortraitState.Combat;
    }

    private void ClearPlan()
    {
        ParsedPayload         = null;
        Optimization          = null;
        ParseError            = null;
        GeneratedImportString = "";
        ExportString          = "";
        ActiveJobOverride     = null;
        Portrait              = PortraitState.Ready;
    }

    private async Task CopyImportString()
    {
        if (string.IsNullOrEmpty(GeneratedImportString)) return;
        try
        {
            await JS.InvokeVoidAsync(
                "navigator.clipboard.writeText", GeneratedImportString);
        }
        catch { /* readonly textarea allows manual copy */ }
    }

    // ═════════════════════════════════════════════════════════════════
    //  ADVENTURER CARD HELPERS
    // ═════════════════════════════════════════════════════════════════
    private string AdvDisplayName() =>
        ParsedPayload?.Character is { } c
            ? $"{c.JobAbbreviation} · Lv {c.Level}"
            : "Adventurer";

    private string AdvJob()     => ParsedPayload?.Character?.JobAbbreviation ?? "—";
    private string AdvJobName() => ParsedPayload?.Character?.JobAbbreviation is { Length: > 0 } a
        ? JobFullName(a) : "";
    private string AdvLevel()   => ParsedPayload?.Character?.Level.ToString() ?? "—";
    private string AdvIlvl()    => ParsedPayload?.Character?.AverageItemLevel.ToString() ?? "—";

    // ═════════════════════════════════════════════════════════════════
    //  GEAR GRID HELPERS — slot-icon glyphs + materia stat classes
    // ═════════════════════════════════════════════════════════════════
    private string SlotGlyph(string slot) => slot.ToLower() switch
    {
        "mainhand"            => "⚔",
        "offhand"             => "⛨",
        "head"                => "⛑",
        "body" or "chest"     => "☗",
        "hands" or "gloves"   => "✋",
        "legs" or "pants"     => "⌷",
        "feet" or "boots"     => "⌒",
        "earrings" or "ears"  => "◊",
        "neck" or "necklace"  => "◊",
        "wrists" or "bracelet" => "⌑",
        "ringleft" or "ringright" or "ring1" or "ring2" => "◯",
        _ => "◆",
    };

    private string MateriaStatClass(string statName) => CanonicalStatKey(statName) switch
    {
        "CRT"  => "crit",
        "DH"   => "dh",
        "DET"  => "det",
        "SKS"  => "sks",
        "SPS"  => "sps",
        "TEN"  => "ten",
        "PIE"  => "pie",
        _      => "",
    };

    // v0.6.4 — Canonicalize stat name. Forwards to Core's shared
    // StatNames.Canonical helper (vendored at Services/Core/StatNames.cs)
    // so the plugin and web can't drift on the matching rules. The
    // plugin emits in-game BaseParam display names ("Critical Hit",
    // "Direct Hit Rate") and older payloads use three-letter codes
    // ("CRT", "DH"); both flow through this helper to a canonical
    // three-letter key the UI's switches match against.
    private static string CanonicalStatKey(string? statName) =>
        GearGoblin.Core.StatNames.Canonical(statName);

    private int GearSlotCount() => ParsedPayload?.Equipped?.Count ?? 0;

    private string GearSetLabel() => ParsedPayload?.Character is { } c
        ? $"iLvl {c.AverageItemLevel}"
        : "—";

    private int TotalMateriaCount() =>
        ParsedPayload?.Equipped?.Sum(p => p.Materia?.Count ?? 0) ?? 0;

    // ═════════════════════════════════════════════════════════════════
    //  STAT PROFILE HELPERS — materia totals (full derivations v0.6.1)
    // ═════════════════════════════════════════════════════════════════
    private record StatCell(string Name, string Value, int MateriaTotal, double PercentOfCap);

    private List<StatCell> BuildStatCells()
    {
        var statKeys = new[] { "CRT", "DH", "DET", "TEN", "SKS", "PIE" };
        var labels   = new Dictionary<string, string>
        {
            ["CRT"] = "Critical Hit", ["DH"]  = "Direct Hit",
            ["DET"] = "Determination",["TEN"] = "Tenacity",
            ["SKS"] = "Skill Speed",  ["PIE"] = "Piety",
        };
        var totals = new Dictionary<string, int>();
        foreach (var k in statKeys) totals[k] = 0;

        if (ParsedPayload?.Equipped is { } eq)
        {
            foreach (var piece in eq)
            foreach (var m in piece.Materia ?? new List<ExportMateriaV1>())
            {
                var key = CanonicalStatKey(m.StatName);
                if (totals.ContainsKey(key))
                    totals[key] += m.StatValue;
            }
        }

        var maxTotal = totals.Values.DefaultIfEmpty(0).Max();
        return statKeys.Select(k =>
        {
            var t = totals[k];
            var pct = maxTotal > 0 ? Math.Min(100.0, t / (double)maxTotal * 100.0) : 0.0;
            return new StatCell(labels[k], t > 0 ? $"+{t}" : "—", t, pct);
        }).ToList();
    }

    private string StatProfileBadge() => ParsedPayload?.Character is { } c
        ? $"Lv {c.Level} {c.JobAbbreviation} · materia totals only"
        : "awaiting import";

    // ═════════════════════════════════════════════════════════════════
    //  AUDIT HELPERS
    // ═════════════════════════════════════════════════════════════════
    private int AuditEmptyCount() => Optimization?.PlanRecommendations.Count ?? 0;

    private string AuditPipClass(int count)
    {
        if (ParsedPayload == null) return "ok";
        return count > 4 ? "error" : count > 0 ? "warn" : "ok";
    }

    private string JobAbbr() => ParsedPayload?.Character?.JobAbbreviation ?? "?";

    // v0.6.5 — Real audit logic. Output shape deliberately mirrors the
    // plugin's MeldAudit record (Piece / PieceName / SlotIndex /
    // CurrentMateriaName / Severity / Headline / Detail) so a future
    // consolidation into GearGoblin.Core can swap the source without
    // changing the UI. Pure-Math severity levels:
    //   - Wrong stat → Warning (stat outside active job's priority list)
    //   - Under-tier → Minor   (grade < CurrentCapTier)
    //   - Overcap    → Warning (piece has 2+ Tier XII melds on same stat)
    private sealed record AuditFinding(
        string Piece,
        int    SlotIndex,
        string CurrentMateriaName,
        string Headline,
        string Detail,
        bool   IsWrongStat,
        bool   IsUnderTier,
        bool   IsOvercap);

    private List<AuditFinding>? cachedFindings;
    private ExportPayloadV1?    findingsBoundTo;

    private List<AuditFinding> BuildAuditFindings()
    {
        if (ParsedPayload == null) return new();
        if (cachedFindings != null && ReferenceEquals(findingsBoundTo, ParsedPayload))
            return cachedFindings;

        var findings = new List<AuditFinding>();
        var jobAbbr  = ParsedPayload.Character?.JobAbbreviation ?? "";
        var priority = GearGoblin.Core.JobPriorities.For(jobAbbr);
        var capTier  = GearGoblin.Core.MateriaTiers.CurrentCapTier;

        // Build the set of canonical priority keys for the active job
        // (for the wrong-stat check). Take all entries — Pure-Math
        // recommends across the full priority list, so a stat being
        // outside the list is what makes it "wrong" rather than just
        // "suboptimal".
        var priorityKeys = new HashSet<string>(
            priority.Select(GearGoblin.Core.StatNames.Canonical),
            StringComparer.Ordinal);

        foreach (var piece in ParsedPayload.Equipped ?? new List<ExportPieceV1>())
        {
            if (piece.Materia is not { Count: > 0 }) continue;

            // Per-piece tally for the overcap heuristic — count
            // Tier-XII materia per canonical stat key. Two+ on the
            // same stat in the same piece very likely overcaps the
            // piece's per-stat cap (Tier XII = +54 per slot; most
            // piece-caps are around +150, two Tier XII = +108
            // legit, but a third+ would overcap).
            var perStatCapTier = new Dictionary<string, int>(StringComparer.Ordinal);

            foreach (var m in piece.Materia)
            {
                // v0.6.5.1 — Wire format's Grade field is 0-indexed: a Tier XII
                // materia (highest current cap, Patch 7.x) arrives as Grade=11
                // because the plugin reads it raw from FFXIV's
                // GameInventoryItem.MateriaGrade[i], which uses the game's
                // 0-based tier index. Core's MateriaTiers.CurrentCapTier is
                // 1-indexed (=12 for Tier XII), and RomanGrade was being
                // handed the raw 0-indexed value, rendering Tier XII as "XI"
                // and flagging every Tier XII meld as under-tier. Add 1 here
                // — at the consumer — so the wire format itself stays
                // unchanged and we don't churn the GG-EXPORT:v1: schema.
                var displayGrade = m.Grade + 1;

                var canonical = GearGoblin.Core.StatNames.Canonical(m.StatName);
                if (displayGrade >= capTier)
                {
                    perStatCapTier[canonical] =
                        perStatCapTier.TryGetValue(canonical, out var c) ? c + 1 : 1;
                }

                bool wrongStat = !string.IsNullOrEmpty(canonical) && !priorityKeys.Contains(canonical);
                bool underTier = displayGrade < capTier;

                if (wrongStat || underTier)
                {
                    var headline = wrongStat
                        ? $"{m.StatName} not in {jobAbbr} priority"
                        : $"Tier {RomanGrade(displayGrade)} below cap (XII)";

                    var detail = wrongStat
                        ? $"→ Replace with priority stat ({string.Join(" › ", priority.Take(3))})"
                        : $"→ Upgrade to Tier XII (+{GearGoblin.Core.MateriaTiers.SubstatValue(capTier)})";

                    findings.Add(new AuditFinding(
                        Piece:              piece.Slot,
                        SlotIndex:          m.SlotIndex,
                        CurrentMateriaName: $"{m.StatName} {RomanGrade(displayGrade)} (+{m.StatValue})",
                        Headline:           headline,
                        Detail:             detail,
                        IsWrongStat:        wrongStat,
                        IsUnderTier:        underTier,
                        IsOvercap:          false));
                }
            }

            // After scanning the piece's materia, flag overcap pieces
            // (3+ Tier XII on one stat; 2 is legit double-meld baseline).
            foreach (var (stat, count) in perStatCapTier)
            {
                if (count < 3) continue;
                findings.Add(new AuditFinding(
                    Piece:              piece.Slot,
                    SlotIndex:          -1,
                    CurrentMateriaName: $"{count}× Tier XII {GearGoblin.Core.StatNames.DisplayName(stat)}",
                    Headline:           "Likely overcap on this piece",
                    Detail:             $"→ Extract one and meld a different priority stat",
                    IsWrongStat:        false,
                    IsUnderTier:        false,
                    IsOvercap:          true));
            }
        }

        cachedFindings   = findings;
        findingsBoundTo  = ParsedPayload;
        return findings;
    }

    private int AuditWrongStatCount() => BuildAuditFindings().Count(f => f.IsWrongStat);
    private int AuditUnderTierCount() => BuildAuditFindings().Count(f => f.IsUnderTier);
    private int AuditOvercapCount()   => BuildAuditFindings().Count(f => f.IsOvercap);

    // Sell/replace count = unique findings (one per problematic materia).
    // Overcap findings flag the piece, not a specific materia, so they
    // don't add to the per-materia replace count.
    private int AuditReplaceCount() =>
        BuildAuditFindings().Count(f => f.IsWrongStat || f.IsUnderTier);

    private bool ShowSellBreakdown { get; set; }
    private void ToggleSellBreakdown() => ShowSellBreakdown = !ShowSellBreakdown;

    private List<AuditFinding> BuildSellBreakdown() =>
        BuildAuditFindings()
            .Where(f => f.IsWrongStat || f.IsUnderTier || f.IsOvercap)
            .ToList();

    private static string RomanGrade(int grade) => grade switch
    {
        1  => "I",   2  => "II",  3  => "III", 4  => "IV",
        5  => "V",   6  => "VI",  7  => "VII", 8  => "VIII",
        9  => "IX",  10 => "X",   11 => "XI",  12 => "XII",
        _  => grade.ToString(),
    };

    // ═════════════════════════════════════════════════════════════════
    //  ADVISOR — circled-number glyphs for rank
    // ═════════════════════════════════════════════════════════════════
    private string CircledNum(int n) => n switch
    {
        1 => "①", 2 => "②", 3 => "③", 4 => "④", 5 => "⑤",
        6 => "⑥", 7 => "⑦", 8 => "⑧", 9 => "⑨", 10 => "⑩",
        _ => $"({n})",
    };

    // ═════════════════════════════════════════════════════════════════
    //  OPTIMIZER — 21-job picker
    // ═════════════════════════════════════════════════════════════════
    private static readonly (string Abbr, string Role)[] AllJobs = new[]
    {
        ("PLD","tank"),  ("WAR","tank"),  ("DRK","tank"),  ("GNB","tank"),
        ("WHM","healer"),("SCH","healer"),("AST","healer"),("SGE","healer"),
        ("MNK","dps"),   ("DRG","dps"),   ("NIN","dps"),   ("SAM","dps"),
        ("RPR","dps"),   ("VPR","dps"),
        ("BRD","dps"),   ("MCH","dps"),   ("DNC","dps"),
        ("BLM","dps"),   ("SMN","dps"),   ("RDM","dps"),   ("PCT","dps"),
    };

    private string ActiveJob() =>
        ActiveJobOverride
        ?? ParsedPayload?.Character?.JobAbbreviation
        ?? "GNB";

    private static string JobFullName(string abbr) => abbr.ToUpper() switch
    {
        "PLD" => "Paladin",      "WAR" => "Warrior",     "DRK" => "Dark Knight",  "GNB" => "Gunbreaker",
        "WHM" => "White Mage",   "SCH" => "Scholar",     "AST" => "Astrologian",  "SGE" => "Sage",
        "MNK" => "Monk",         "DRG" => "Dragoon",     "NIN" => "Ninja",        "SAM" => "Samurai",
        "RPR" => "Reaper",       "VPR" => "Viper",
        "BRD" => "Bard",         "MCH" => "Machinist",   "DNC" => "Dancer",
        "BLM" => "Black Mage",   "SMN" => "Summoner",    "RDM" => "Red Mage",     "PCT" => "Pictomancer",
        _ => "",
    };

    // ═════════════════════════════════════════════════════════════════
    //  v0.5.4 FEEDBACK PANEL — state + handlers (unchanged)
    // ═════════════════════════════════════════════════════════════════
    private const string FeedbackRepoUrl =
        "https://github.com/LastOnionKnight/TonberryTactics";

    private static readonly string[] FeedbackCategories =
        { "Bug / glitch", "Optimizer disagreement", "Confusion / unclear", "Just saying hi" };
    private static readonly string[] FeedbackLabels =
        { "bug", "optimizer", "ux", "feedback" };

    private int    FeedbackCategory    = 0;
    private string FeedbackText        = string.Empty;
    private bool   FeedbackIncludeDiag = true;
    private string FeedbackLastAction  = string.Empty;

    private bool HasFeedbackText => !string.IsNullOrWhiteSpace(FeedbackText);

    private async Task OpenGitHubIssue()
    {
        if (!HasFeedbackText) return;
        try
        {
            var url = await BuildGitHubIssueUrlAsync();
            await JS.InvokeVoidAsync("window.open", url, "_blank", "noopener");
            FeedbackLastAction =
                $"✓ Opened GitHub issue in a new tab at {DateTime.Now:HH:mm:ss}. Edit and submit there.";
            FeedbackText = string.Empty;
        }
        catch (Exception ex)
        {
            FeedbackLastAction =
                $"Couldn't open browser tab ({ex.GetType().Name}). Try the Copy button instead.";
        }
    }

    private async Task CopyFeedbackPayload()
    {
        if (!HasFeedbackText) return;
        try
        {
            var payload = await BuildFeedbackPayloadAsync();
            await JS.InvokeVoidAsync(
                "navigator.clipboard.writeText", payload);
            FeedbackLastAction =
                $"✓ Copied to clipboard at {DateTime.Now:HH:mm:ss}. Paste in the FC Discord or DM Refia.";
            FeedbackText = string.Empty;
        }
        catch
        {
            FeedbackLastAction =
                "Couldn't access clipboard — browser may have blocked it. Try the GitHub button.";
        }
    }

    private async Task<string> BuildGitHubIssueUrlAsync()
    {
        var category = FeedbackCategories[FeedbackCategory];
        var label    = FeedbackLabels[FeedbackCategory];
        var title    = $"[v{TtVersion}] [{category}] ";
        var body     = await BuildFeedbackPayloadAsync();

        var titleEnc = Uri.EscapeDataString(title);
        var bodyEnc  = Uri.EscapeDataString(body);
        var labelEnc = Uri.EscapeDataString(label);

        return $"{FeedbackRepoUrl}/issues/new" +
               $"?title={titleEnc}&body={bodyEnc}&labels={labelEnc}";
    }

    private async Task<string> BuildFeedbackPayloadAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("### Category");
        sb.AppendLine(FeedbackCategories[FeedbackCategory]);
        sb.AppendLine();
        sb.AppendLine("### Message");
        sb.AppendLine(FeedbackText.Trim());
        sb.AppendLine();
        if (FeedbackIncludeDiag)
        {
            sb.AppendLine("### Diagnostic info");
            sb.AppendLine("```");
            sb.AppendLine($"TT version:        {TtVersion}");

            string userAgent = "(unavailable)";
            try
            {
                userAgent = await JS.InvokeAsync<string>(
                    "eval", "navigator.userAgent");
            }
            catch { /* swallow */ }
            sb.AppendLine($"User agent:        {userAgent}");

            sb.AppendLine($"Has export loaded: {!string.IsNullOrWhiteSpace(ExportString)}");
            sb.AppendLine($"Active job:        {(ParsedPayload?.Character?.JobAbbreviation ?? "(none)")}");
            sb.AppendLine($"Optimizer ran:     {Optimization != null}");
            sb.AppendLine($"Plan emitted:      {!string.IsNullOrEmpty(GeneratedImportString)}");
            sb.AppendLine($"Generated at:      {DateTime.UtcNow:o}");
            sb.AppendLine("```");
        }
        return sb.ToString();
    }
}








