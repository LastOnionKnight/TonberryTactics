@page "/"
@using TonberryTactics.Models
@using TonberryTactics.Services
@inject IJSRuntime JS

@*
    Tonberry Tactics v0.5.2 — Index.razor

    v0.5.2 is a docs/version alignment release for GearGoblin v0.4.5
    (which became a full CharacterPanelRefined replacement). No
    optimizer, parser, or wire-format changes — GG-EXPORT:v1: is
    still consumed unchanged. See CHANGELOG for the full entry.
    -----------------------------------------------------------------
    Retro Final Fantasy (SNES/PS1) UI for the AskMrRobot-style hybrid
    gear optimizer. All CSS is scoped under .ff-theme-wrapper.

    v0.5.1 wires the mock optimizer to a real GG-EXPORT:v1: parser,
    a hardcoded GNB Pure-Math optimizer, and a GG-PLAN:v1: serializer.
    Portrait icons (wwwroot/portraits/*.jpg) now switch with state.

    The knife cursor is inline SVG (no external image asset required).
    If/when /images/tonberry-knife.png exists, swap the <svg> inside
    .knife-cursor for an <img> — animation continues to work.
*@

<style>
    /* === Tonberry Tactics — Retro FF UI =========================== */
    /* All styling scoped inside .ff-theme-wrapper.                  */

    @@import url('https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&display=swap');

    .ff-theme-wrapper {
        font-family: 'VT323', 'Courier New', monospace;
        font-size: 22px;
        line-height: 1.25;
        color: #ffffff;
        background:
            radial-gradient(ellipse at 20% 10%, rgba(64,96,192,0.18), transparent 55%),
            radial-gradient(ellipse at 85% 95%, rgba(109,180,78,0.10), transparent 55%),
            linear-gradient(180deg, #060a28 0%, #14184c 50%, #060a28 100%);
        min-height: 100vh;
        padding: 28px 22px 48px;
        letter-spacing: 0.5px;
    }
    .ff-theme-wrapper * { box-sizing: border-box; }
    .ff-theme-wrapper a { color: #ffcc44; text-decoration: none; }

    /* ---- Header / masthead -------------------------------------- */
    .ff-theme-wrapper .tt-header {
        text-align: center;
        margin-bottom: 26px;
        padding-bottom: 18px;
        border-bottom: 2px solid #4060a0;
    }
    .ff-theme-wrapper .tt-logo {
        font-family: 'Press Start 2P', 'Courier New', monospace;
        font-size: 26px;
        color: #ffcc44;
        text-shadow: 3px 3px 0 #663300, 6px 6px 0 rgba(0,0,0,0.55);
        letter-spacing: 3px;
        margin-bottom: 12px;
    }
    .ff-theme-wrapper .tt-tag {
        font-size: 20px;
        color: #c0d0ff;
        font-style: italic;
        margin-bottom: 6px;
    }
    .ff-theme-wrapper .tt-version {
        font-size: 13px;
        color: #6080c0;
        letter-spacing: 2px;
        font-family: 'Press Start 2P', monospace;
    }

    /* ---- Menu Box (classic FF window) --------------------------- */
    .ff-theme-wrapper .menu-box {
        background: linear-gradient(180deg, #181c5e 0%, #0a0e3a 100%);
        border: 3px solid #ffffff;
        border-radius: 0;
        box-shadow:
            inset 0 0 0 1px #6080c0,
            0 0 0 1px #1a1e4a,
            4px 4px 0 rgba(0,0,0,0.55);
        margin-bottom: 18px;
    }
    .ff-theme-wrapper .menu-box-title {
        background: linear-gradient(180deg, #2040a0 0%, #102078 100%);
        color: #ffcc44;
        font-family: 'Press Start 2P', monospace;
        font-size: 12px;
        padding: 9px 14px;
        border-bottom: 2px solid #ffffff;
        letter-spacing: 1.5px;
        text-shadow: 1px 1px 0 #000000;
    }
    .ff-theme-wrapper .menu-box-body {
        padding: 16px 18px 18px;
    }
    .ff-theme-wrapper .menu-box-body p {
        margin: 0 0 10px 0;
    }
    .ff-theme-wrapper .menu-box-body p:last-child {
        margin-bottom: 0;
    }
    /* v0.5.2: accent variant for the Plugin Update callout — amber border
       and title bar to flag "this is news," not a control. */
    .ff-theme-wrapper .menu-box-accent {
        background: linear-gradient(180deg, #2a1f4f 0%, #15082b 100%);
        border-color: #ffcc44;
        box-shadow:
            inset 0 0 0 1px #ffcc44,
            0 0 0 1px #6a4a0d,
            4px 4px 0 rgba(0,0,0,0.55);
    }
    .ff-theme-wrapper .menu-box-accent .menu-box-title {
        background: linear-gradient(180deg, #b08820 0%, #6a4a0d 100%);
        color: #ffeb99;
        border-bottom-color: #ffcc44;
    }

    /* ---- Buttons ------------------------------------------------ */
    .ff-theme-wrapper .ff-button {
        background: linear-gradient(180deg, #4060c0 0%, #1f3690 100%);
        border: 2px solid #ffffff;
        border-radius: 0;
        color: #ffffff;
        font-family: 'Press Start 2P', monospace;
        font-size: 11px;
        padding: 9px 16px;
        cursor: pointer;
        letter-spacing: 1.5px;
        text-shadow: 1px 1px 0 #000000;
        box-shadow:
            inset 0 0 0 1px #80a0ff,
            2px 2px 0 rgba(0,0,0,0.55);
        transition: filter 0.1s ease;
        margin: 4px 6px 4px 0;
    }
    .ff-theme-wrapper .ff-button:hover { filter: brightness(1.18); }
    .ff-theme-wrapper .ff-button:active {
        transform: translate(2px, 2px);
        box-shadow: inset 0 0 0 1px #80a0ff;
    }
    .ff-theme-wrapper .ff-button-primary {
        background: linear-gradient(180deg, #d8b042 0%, #8e6418 100%);
        border-color: #ffcc44;
        box-shadow:
            inset 0 0 0 1px #ffd866,
            2px 2px 0 rgba(0,0,0,0.55);
    }
    .ff-theme-wrapper .ff-button[disabled] {
        opacity: 0.45;
        cursor: not-allowed;
        filter: grayscale(0.6);
    }

    /* ---- Textarea / inputs ------------------------------------- */
    .ff-theme-wrapper .ff-textarea {
        width: 100%;
        background: #00001e;
        border: 2px solid #4060a0;
        color: #ffffff;
        font-family: 'VT323', monospace;
        font-size: 18px;
        padding: 8px 10px;
        resize: vertical;
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }
    .ff-theme-wrapper .ff-textarea:focus {
        outline: none;
        border-color: #80a0ff;
        box-shadow: 0 0 0 1px #ffcc44;
    }
    .ff-theme-wrapper .ff-readonly {
        background: #00000f;
        border-color: #303060;
        color: #ffcc44;
    }

    /* ---- Inline code -------------------------------------------- */
    .ff-theme-wrapper code {
        background: #00001e;
        color: #ffcc44;
        padding: 1px 7px;
        font-family: 'VT323', monospace;
        font-size: 18px;
        border: 1px solid #4060a0;
    }

    /* ---- Layout grid -------------------------------------------- */
    .ff-theme-wrapper .hero { margin-bottom: 20px; }
    .ff-theme-wrapper .hero-instructions {
        color: #c0d0ff;
        font-size: 18px;
    }
    .ff-theme-wrapper .content-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
    }
    @@media (max-width: 900px) {
        .ff-theme-wrapper .content-grid { grid-template-columns: 1fr; }
    }

    /* ---- Sidebar: Adventurer block ------------------------------ */
    .ff-theme-wrapper .char-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 5px 0;
        border-bottom: 1px dashed #303068;
    }
    .ff-theme-wrapper .char-row:last-child { border-bottom: none; }
    .ff-theme-wrapper .char-label {
        color: #8090c0;
        font-size: 16px;
        letter-spacing: 2px;
        font-family: 'Press Start 2P', monospace;
    }
    .ff-theme-wrapper .char-value {
        color: #ffffff;
        font-size: 22px;
    }
    .ff-theme-wrapper .char-value-good   { color: #6db44e; }
    .ff-theme-wrapper .char-value-wait   { color: #c0d0ff; }
    .ff-theme-wrapper .char-value-accent { color: #ffcc44; }

    /* ---- Materia list ------------------------------------------- */
    .ff-theme-wrapper .materia-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .ff-theme-wrapper .materia-row {
        display: flex;
        align-items: center;
        padding: 7px 8px;
        border-bottom: 1px solid #1a2456;
        font-size: 22px;
    }
    .ff-theme-wrapper .materia-row:last-child { border-bottom: none; }
    .ff-theme-wrapper .materia-row:hover {
        background: rgba(64,96,192,0.15);
    }
    .ff-theme-wrapper .materia-piece {
        flex: 1;
        color: #ffffff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ff-theme-wrapper .materia-slot {
        color: #8090c0;
        margin-right: 14px;
        min-width: 36px;
        text-align: right;
        font-family: 'VT323', monospace;
    }
    .ff-theme-wrapper .materia-arrow {
        color: #6080c0;
        margin-right: 10px;
    }
    .ff-theme-wrapper .materia-meld {
        color: #ffcc44;
        min-width: 110px;
        text-align: right;
    }

    /* ---- The Tonberry Knife Cursor ------------------------------ */
    /* Inline SVG knife with a "stab" animation. Pixelated rendering
       so it slots into the retro aesthetic without anti-aliasing. */
    .ff-theme-wrapper .knife-cursor {
        display: inline-block;
        width: 32px;
        height: 16px;
        margin-right: 10px;
        flex-shrink: 0;
        animation: stab 0.85s ease-in-out infinite;
    }
    .ff-theme-wrapper .knife-cursor svg {
        width: 100%;
        height: 100%;
        display: block;
        image-rendering: pixelated;
        filter: drop-shadow(1px 1px 0 rgba(0,0,0,0.7));
    }
    @@keyframes stab {
        0%, 55%, 100% { transform: translateX(0); }
        65%           { transform: translateX(9px); }
        75%           { transform: translateX(6px); }
        85%           { transform: translateX(2px); }
    }

    /* ---- Empty state -------------------------------------------- */
    .ff-theme-wrapper .empty-state {
        text-align: center;
        padding: 36px 16px;
        color: #8090c0;
    }
    .ff-theme-wrapper .empty-state .empty-icon {
        font-size: 44px;
        margin-bottom: 14px;
        opacity: 0.7;
    }
    .ff-theme-wrapper .empty-state p {
        margin: 4px 0;
        font-size: 20px;
    }
    .ff-theme-wrapper .muted { color: #6080c0; font-size: 18px; }
    .ff-theme-wrapper .hint  {
        font-size: 16px;
        color: #6080c0;
        margin-top: 8px;
        font-style: italic;
    }

    /* ---- Footer ------------------------------------------------- */
    .ff-theme-wrapper .tt-footer {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 2px solid #4060a0;
        color: #6080c0;
        font-size: 16px;
        font-style: italic;
        line-height: 1.6;
    }
    .ff-theme-wrapper .tt-footer .tlf-mark {
        color: #6db44e;
        font-style: normal;
        letter-spacing: 2px;
        font-family: 'Press Start 2P', monospace;
        font-size: 11px;
    }
    /* ---- Adventurer portrait (v0.5.1) --------------------------- */
    .ff-theme-wrapper .portrait-frame {
        width: 100%;
        aspect-ratio: 1 / 1;
        margin: 0 0 14px 0;
        border: 3px solid #ffffff;
        background: #060a28;
        box-shadow:
            inset 0 0 0 1px #6080c0,
            0 0 0 1px #1a1e4a,
            3px 3px 0 rgba(0,0,0,0.55);
        position: relative;
        overflow: hidden;
    }
    .ff-theme-wrapper .portrait-frame img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        image-rendering: auto;
        transition: opacity 0.18s ease-out;
    }
    .ff-theme-wrapper .portrait-state-tag {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 4px 8px;
        font-family: 'Press Start 2P', monospace;
        font-size: 9px;
        letter-spacing: 1.5px;
        text-align: center;
        background: rgba(6,10,40,0.85);
        border-top: 1px solid #4060a0;
    }
    .ff-theme-wrapper .portrait-state-ready  { color: #6db44e; }
    .ff-theme-wrapper .portrait-state-combat { color: #ffcc44; }
    .ff-theme-wrapper .portrait-state-danger { color: #ff6644; }

    /* ---- Error banner (v0.5.1) ---------------------------------- */
    .ff-theme-wrapper .ff-error {
        background: linear-gradient(180deg, #5e1818 0%, #3a0a0a 100%);
        border: 3px solid #ff6644;
        box-shadow:
            inset 0 0 0 1px #ffaa88,
            0 0 0 1px #2a0606,
            4px 4px 0 rgba(0,0,0,0.55);
        color: #ffdddd;
        padding: 14px 18px;
        margin-bottom: 18px;
        font-size: 18px;
    }
    .ff-theme-wrapper .ff-error .ff-error-title {
        font-family: 'Press Start 2P', monospace;
        font-size: 11px;
        color: #ff6644;
        letter-spacing: 1.5px;
        margin-bottom: 6px;
        text-shadow: 1px 1px 0 #000;
    }
</style>


<div class="ff-theme-wrapper">

    <!-- ============================================================
         HEADER
         ============================================================ -->
    <header class="tt-header">
        <div class="tt-logo">▶ TONBERRY TACTICS</div>
        <div class="tt-tag">"No gear. No hope. No pants. Just onions."</div>
        <div class="tt-version">TLF GEAR DIVISION &nbsp;·&nbsp; v0.5.2 &nbsp;·&nbsp; for GearGoblin v0.4.5+</div>
    </header>


    <!-- ============================================================
         HERO — paste export string
         ============================================================ -->
    <section class="hero">
        <div class="menu-box">
            <div class="menu-box-title">▶ IMPORT FIELD DATA</div>
            <div class="menu-box-body">
                <p class="hero-instructions">
                    Paste your exported gear string from the in-game plugin
                    (run <code>/goblinexport</code> in chat, then Ctrl+V here).
                </p>
                <textarea class="ff-textarea"
                          @bind="ExportString"
                          placeholder="GG-EXPORT:..."
                          rows="3"></textarea>
                <button class="ff-button ff-button-primary"
                        @onclick="RunOptimization"
                        disabled="@string.IsNullOrWhiteSpace(ExportString)">
                    ⚔ OPTIMIZE
                </button>
                @if (Optimization != null || ParseError != null)
                {
                    <button class="ff-button" @onclick="ClearPlan">
                        ✕ CLEAR
                    </button>
                }
            </div>
        </div>
    </section>


    @if (!string.IsNullOrEmpty(ParseError))
    {
        <div class="ff-error">
            <div class="ff-error-title">▶ PARSE ERROR</div>
            @ParseError
        </div>
    }


    <!-- ============================================================
         TWO-COLUMN: Sidebar + Materia main
         ============================================================ -->
    <div class="content-grid">

        <!-- ---- SIDEBAR ---- -->
        <aside>

            <!-- Adventurer status -->
            <div class="menu-box">
                <div class="menu-box-title">▶ ADVENTURER</div>
                <div class="menu-box-body">
                    <div class="portrait-frame">
                        <img src="portraits/@(CurrentPortrait()).jpg"
                             alt="Adventurer portrait"
                             loading="lazy" />
                        <div class="portrait-state-tag @PortraitStateClass()">
                            @PortraitStateLabel()
                        </div>
                    </div>
                    <div class="char-row">
                        <span class="char-label">JOB</span>
                        <span class="char-value char-value-accent">
                            @(ParsedPayload?.Character.JobAbbreviation ?? "—")
                        </span>
                    </div>
                    <div class="char-row">
                        <span class="char-label">LEVEL</span>
                        <span class="char-value">
                            @(ParsedPayload?.Character.Level.ToString() ?? "—")
                        </span>
                    </div>
                    <div class="char-row">
                        <span class="char-label">ILVL</span>
                        <span class="char-value">
                            @(ParsedPayload?.Character.AverageItemLevel.ToString() ?? "—")
                        </span>
                    </div>
                    <div class="char-row">
                        <span class="char-label">STATUS</span>
                        @if (Optimization == null && ParseError == null)
                        {
                            <span class="char-value char-value-wait">AWAITING</span>
                        }
                        else if (Optimization == null)
                        {
                            <span class="char-value char-value-wait">ERROR</span>
                        }
                        else
                        {
                            <span class="char-value char-value-good">READY</span>
                        }
                    </div>
                    <div class="char-row">
                        <span class="char-label">MELDS</span>
                        <span class="char-value">
                            @(Optimization?.Recommendations.Count ?? 0)
                        </span>
                    </div>
                </div>
            </div>

            <!-- Output string for re-import -->
            <div class="menu-box">
                <div class="menu-box-title">▶ EXPORT TO GAME</div>
                <div class="menu-box-body">
                    @if (string.IsNullOrEmpty(GeneratedImportString))
                    {
                        <p class="muted">
                            Run the optimizer to generate an import string.
                        </p>
                    }
                    else
                    {
                        <textarea class="ff-textarea ff-readonly"
                                  readonly
                                  rows="3">@GeneratedImportString</textarea>
                        <button class="ff-button"
                                @onclick="CopyImportString">
                            ⚔ COPY
                        </button>
                        <p class="hint">
                            Paste into the in-game plugin via
                            <code>/goblin import</code>.
                        </p>
                    }
                </div>
            </div>

            <!-- Plugin update callout (v0.5.2 — GG v0.4.5 alignment) -->
            <div class="menu-box menu-box-accent">
                <div class="menu-box-title">▶ PLUGIN UPDATE</div>
                <div class="menu-box-body">
                    <p class="muted">
                        <strong>GearGoblin v0.4.5</strong> — full Character Panel
                        takeover. Compact derived stats per substat, breakpoint
                        hints inline, real GCD, role-gated Tenacity / Piety, and
                        the Materia Advisor — all in one plugin. Replaces
                        CharacterPanelRefined entirely (auto-detects CPR and
                        steps aside if both are installed).
                    </p>
                    <p class="hint">
                        Tonberry Tactics consumes the same <code>GG-EXPORT:v1:</code>
                        wire format; this site is fully compatible with the
                        update.
                    </p>
                </div>
            </div>

        </aside>


        <!-- ---- MAIN: Materia recommendations ---- -->
        <main>
            <div class="menu-box">
                <div class="menu-box-title">▶ MATERIA REQUIRED</div>
                <div class="menu-box-body">

                    @if (Optimization == null)
                    {
                        <div class="empty-state">
                            <div class="empty-icon">📜</div>
                            <p>No optimization run yet.</p>
                            <p class="muted">
                                Paste your export string above and click
                                OPTIMIZE.
                            </p>
                        </div>
                    }
                    else if (Optimization.Recommendations.Count == 0)
                    {
                        <div class="empty-state">
                            <div class="empty-icon">✓</div>
                            <p>All guaranteed slots filled — no melds required.</p>
                            <p class="muted">
                                Your gear's empty slots are fully accounted for.
                                The Tonberry approves.
                            </p>
                        </div>
                    }
                    else
                    {
                        <p class="muted" style="margin-bottom:14px;">
                            Mode: <strong>@Optimization.OptimizationMode</strong>
                            &nbsp;·&nbsp; @Optimization.TotalEmptySlots empty slot(s) filled
                        </p>
                        <ul class="materia-list">
                            @foreach (var rec in Optimization.Recommendations)
                            {
                                <li class="materia-row">
                                    <span class="knife-cursor"
                                          aria-hidden="true">
                                        <!-- Pixel chef's knife. Swap to <img>
                                             when tonberry-knife.png exists. -->
                                        <svg viewBox="0 0 32 16"
                                             preserveAspectRatio="none">
                                            <!-- Wood handle -->
                                            <rect x="2" y="6" width="8" height="4"
                                                  fill="#6b3a1f"/>
                                            <rect x="3" y="7" width="6" height="2"
                                                  fill="#8b5a2f"/>
                                            <!-- Brass bolster -->
                                            <rect x="10" y="5" width="2" height="6"
                                                  fill="#a87b3f"/>
                                            <!-- Silver blade -->
                                            <polygon points="12,5 30,8 12,11"
                                                     fill="#c8c8d0"/>
                                            <!-- Edge highlight -->
                                            <polygon points="12,5 30,8 14,7"
                                                     fill="#e8e8f0"/>
                                        </svg>
                                    </span>
                                    <span class="materia-piece">
                                        @rec.PieceName
                                    </span>
                                    <span class="materia-slot">
                                        #@(rec.SlotIndex + 1)
                                    </span>
                                    <span class="materia-arrow">←</span>
                                    <span class="materia-meld">
                                        @rec.MateriaName
                                    </span>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>
        </main>

    </div>


    <!-- ============================================================
         FOOTER
         ============================================================ -->
    <footer class="tt-footer">
        <div class="tlf-mark">◆ TONBERRY LIBERATION FRONT ◆</div>
        A Refia Rakkiri production · "Stab once, stab true."
    </footer>

</div>


@code {
    // ── Constants (v0.5.1) ────────────────────────────────────────────
    private const string EmitterVersion = "0.5.1";

    // ── Input / output state ──────────────────────────────────────────
    private string  ExportString          = "";
    private string  GeneratedImportString = "";

    // ── Parser + optimizer state. ParsedPayload is the real DTO from
    //    GG-EXPORT:v1: deserialization; Optimization is the result from
    //    PureMathOptimizer; ParseError surfaces any failure to the UI.
    private ExportPayloadV1?       ParsedPayload;
    private PureMathOptimizer.Result? Optimization;
    private string?                ParseError;

    // ── Portrait state machine. ───────────────────────────────────────
    //    READY    → portrait_danger       (subdued red ring, neutral)
    //    COMBAT   → portrait_combat       (lightning energy, engaged)
    //    DANGER   → portrait_danger_alt1  (vivid red, alert)
    private enum PortraitState { Ready, Combat, Danger }
    private PortraitState Portrait = PortraitState.Ready;

    private string CurrentPortrait() => Portrait switch
    {
        PortraitState.Combat => "portrait_combat",
        PortraitState.Danger => "portrait_danger_alt1",
        _                    => "portrait_danger",
    };
    private string PortraitStateClass() => Portrait switch
    {
        PortraitState.Combat => "portrait-state-combat",
        PortraitState.Danger => "portrait-state-danger",
        _                    => "portrait-state-ready",
    };
    private string PortraitStateLabel() => Portrait switch
    {
        PortraitState.Combat => "▶ ENGAGED",
        PortraitState.Danger => "▶ WARNING",
        _                    => "▶ AWAITING",
    };

    // ── Real optimizer pipeline (v0.5.1) ──────────────────────────────
    private void RunOptimization()
    {
        if (string.IsNullOrWhiteSpace(ExportString)) return;

        // Reset state for a fresh run.
        ParsedPayload         = null;
        Optimization          = null;
        ParseError            = null;
        GeneratedImportString = "";

        // 1. Parse the GG-EXPORT:v1: string.
        var parseResult = GearsetParser.TryParse(ExportString);
        if (!parseResult.Success || parseResult.Payload is null)
        {
            ParseError = parseResult.Error ?? "Unknown parse error.";
            Portrait   = PortraitState.Danger;
            return;
        }
        ParsedPayload = parseResult.Payload;

        // 2. Run the hardcoded GNB Pure-Math optimizer.
        Optimization = PureMathOptimizer.Optimize(ParsedPayload);

        // 3. Emit the GG-PLAN:v1: round-trip string.
        GeneratedImportString = PlanSerializer.Serialize(
            Optimization, ParsedPayload, EmitterVersion);

        // 4. Update portrait — show ENGAGED on success regardless of
        //    whether we found anything to recommend, since parse worked.
        Portrait = PortraitState.Combat;
    }

    private void ClearPlan()
    {
        ParsedPayload         = null;
        Optimization          = null;
        ParseError            = null;
        GeneratedImportString = "";
        ExportString          = "";
        Portrait              = PortraitState.Ready;
    }

    // ── Real clipboard via IJSRuntime (v0.5.1) ────────────────────────
    private async Task CopyImportString()
    {
        if (string.IsNullOrEmpty(GeneratedImportString)) return;
        try
        {
            await JS.InvokeVoidAsync(
                "navigator.clipboard.writeText", GeneratedImportString);
        }
        catch
        {
            // Browsers without clipboard API or denied permission: the
            // textarea is rendered readonly so the user can still
            // Ctrl+A / Ctrl+C manually. No UX disaster.
        }
    }
}
