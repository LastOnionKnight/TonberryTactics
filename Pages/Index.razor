@page "/"
@using TonberryTactics.Models
@using TonberryTactics.Services
@using System.Linq
@inject IJSRuntime JS

@*
    Tonberry Tactics v1.1.3 — Index.razor — "Gear Division"

    Full design port from Claude Design's React prototype. Every visible
    component (Header, Import dialog, Adventurer card, Gear grid, Stat
    profile, Materia Advisor, Audit, Optimizer controls, Export card,
    Plugin callout, Feedback, Manifesto, Tonberry trail, Footer) mirrors
    the JSX in app.jsx / chrome.jsx / gear.jsx / advisor.jsx.

    Visual styling is fully external — see wwwroot/css/design-v060.css
    (34KB, ported verbatim from the prototype with the Eorzea @font-face
    path adjusted for Blazor's wwwroot layout).

    C# code-behind preserved from v0.5.5:
      GearsetParser.TryParse → MeldOptimizerAdapter.Optimize → PlanSerializer.Serialize
      Portrait state machine (Ready/Combat/Danger) drives the .state-tag

    Things deliberately deferred to v0.6.1+ (called out so they don't
    masquerade as broken):
      - StatProfile derived rows are "—" (Akhmorning tables ship v0.6.1)
      - Audit wrong-stat / under-tier / overcap rows show "—"
        (full audit logic lives in plugin; web parity via Core refactor)
      - 21-job picker is clickable but the optimizer is still GNB-only
      - Balance preset is queued (Pure-Math is the only active mode)
      - The dev-mode Tweaks panel from the prototype is NOT ported
*@

<HeadContent>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=Cinzel:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/design-v060.css">
</HeadContent>

<div class="shell">

    @* ═══════════════════════════════════════════════════════════════ *@
    @*  HEADER — masthead with crest, brand, TLF stamp, version, expac *@
    @* ═══════════════════════════════════════════════════════════════ *@
    <header class="masthead">
        <div class="crest">
            <img src="assets/circle-logo.png" alt="Tonberry Liberation Front"/>
        </div>
        <div>
            <div class="brand-eyebrow">Tonberry Liberation Front · Gear Division</div>
            <h1 class="brand-title">TONBERRY TACTICS</h1>
            <div class="brand-sub">"No gear. No hope. No pants. Just onions."</div>
            <div class="brand-eorzea">
                <span class="desktop-only" title="Eorzean: Onion of the TLF">ONION · OF · THE · TLF</span>
                <span class="mobile-only">ONION · OF · THE · TLF</span>
            </div>
        </div>
        <div class="tlf-stamp">
            <img src="assets/onion-shield.png" alt="TLF crest"/>
        </div>
        <div class="version-pill">
            <div class="v">v 1.1.3</div>
            <div class="compat">paired with plugin v0.6.0+</div>
        </div>
        <div class="expansion-logo">
            @* v0.6.5.2 — wordmark now links out to the official FFXIV Evercold expansion page.
               target="_blank" + rel="noopener noreferrer" follows the standard external-link
               security pattern: noopener prevents the new tab from controlling our window
               (window.opener tabnabbing), noreferrer suppresses the Referer header. *@
            <a href="https://na.finalfantasyxiv.com/evercold/"
               target="_blank"
               rel="noopener noreferrer"
               class="expansion-link"
               aria-label="Final Fantasy XIV: Evercold — official site (opens in new tab)">
                <img src="assets/evercold-logo-cropped.png" alt="Final Fantasy XIV: Evercold"/>
            </a>
            <div class="patch-tag">
                <span class="dot"></span>
                <span>Patch 7.5 · Expansion live</span>
            </div>
        </div>
    </header>

    @* ═══════════════════════════════════════════════════════════════ *@
    @*  IMPORT SECTION — FF dialog box                                  *@
    @* ═══════════════════════════════════════════════════════════════ *@
    <div class="dlg import-dlg">
        <span class="speaker">ADVENTURER</span>
        <div class="prompt-line">
            <span class="em">Step forward.</span>
            Paste the <code class="inline">GG-EXPORT:v1:</code> string from
            <span class="em">/ttexport</span> to begin the audit.
        </div>
        <div class="import-row">
            <textarea class="import-textarea"
                      @bind="ExportString"
                      @bind:event="oninput"
                      placeholder="GG-EXPORT:v1:eyJwbHVnaW4iOiJUb25iZXJyeVRhY3RpY3MiLi4u"></textarea>
            <button class="step-fwd" @onclick="RunOptimization">
                <span>STEP FORWARD</span>
                <span class="kanji">— stab once, stab true —</span>
            </button>
        </div>
        <div style="margin-top:10px; display:flex; gap:10px; align-items:center; flex-wrap:wrap; font-family:var(--f-mono); font-size:11px; color:var(--frost-dim);">
            @if (ParsedPayload != null)
            {
                <span class="pill ship">
                    parsed · @ParsedPayload.Character.JobAbbreviation ·
                    iLvl @ParsedPayload.Character.AverageItemLevel ·
                    @ParsedPayload.Equipped.Count pieces ·
                    @TotalMateriaCount() melds
                </span>
            }
            else if (!string.IsNullOrWhiteSpace(ParseError))
            {
                <span class="pill error">parse failed</span>
            }
            else
            {
                <span class="pill ice">awaiting export</span>
            }
            <span style="flex:1"></span>
            <button class="btn ghost" @onclick="ClearPlan">CLEAR</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(ParseError))
        {
            <div style="margin-top:10px; padding:10px 12px; border:1px solid var(--blood); background:rgba(210,69,69,0.05); font-family:var(--f-mono); font-size:12px; color:var(--blood-bright);">
                @ParseError
            </div>
        }
    </div>

    @* ═══════════════════════════════════════════════════════════════ *@
    @*  THREE-COLUMN LAYOUT                                             *@
    @* ═══════════════════════════════════════════════════════════════ *@
    <div class="cols">
        <nav class="mobile-tabs">
            <a href="#adventurer">Adventurer</a>
            <a href="#gear">Gear & Stats</a>
            <a href="#optimizer">Config</a>
        </nav>

        @* ─── LEFT — ADVENTURER CARD ──────────────────────────────── *@
        <aside id="adventurer">
            <div class="menu">
                <div class="menu-head">
                    <span class="glyph">◆</span>
                    <span>Adventurer</span>
                    <span class="spacer"></span>
                    <span class="badge">bound</span>
                </div>
                <div class="menu-body">
                    <div class="adv-portrait">
                        <img src="assets/onion-helm.png" alt="Onion Knight portrait"
                             style="width:100%; height:100%; object-fit:contain; display:block;"/>
                        <div class="ring-anim"></div>
                        <div class="state-tag @PipelineTagClass()">◆ @PipelineTagLabel() ◆</div>
                    </div>

                    <h3 class="adv-name">@AdvDisplayName()</h3>
                    <div class="adv-title-line">Onion Knight of the TLF</div>

                    <ul class="adv-stats">
                        <li>
                            <span class="k">Job</span>
                            <span class="v">@AdvJob()</span>
                            <span style="color:var(--frost-dim); font-size:11px; font-family:var(--f-mono);">@AdvJobName()</span>
                        </li>
                        <li><span class="k">Level</span> <span class="v">@AdvLevel()</span></li>
                        <li><span class="k">Avg iLvl</span> <span class="v">@AdvIlvl()</span></li>
                        <li>
                            <span class="k">Melds</span>
                            <span class="v">
                                @if (Optimization != null)
                                {
                                    <span style="color:var(--ship-bright)">+@TotalMateriaCount() queued</span>
                                }
                                else
                                {
                                    <span style="color:var(--frost-dim)">—</span>
                                }
                            </span>
                        </li>
                        <li>
                            <span class="k">Status</span>
                            <span class="v"><span class="pill ship">@PipelineTagLabel()</span></span>
                        </li>
                    </ul>

                    <div class="credo">
                        ◆<br/>
                        "Stab once. Stab true.<br/>
                        The lantern guides, the knife decides."
                        <span class="dash">— TLF CREDO —</span>
                    </div>
                </div>
            </div>
        </aside>

        @* ─── CENTER — GEAR / STATS / ADVISOR / AUDIT ─────────────── *@
        <main id="gear">
            <div class="stack-loose">

                @* GEARSET *@
                <div class="menu no-pad">
                    <div class="menu-head">
                        <span class="glyph">◆</span>
                        <span>Gearset</span>
                        <span class="spacer"></span>
                        <span class="pill ice">@GearSetLabel()</span>
                        <span class="badge">@GearSlotCount() / 13</span>
                    </div>
                    <div class="menu-body">
                        @if (ParsedPayload?.Equipped is { Count: > 0 } pieces)
                        {
                            <div class="gear-grid" style="padding:0; padding-top:4px;">
                                @foreach (var piece in pieces)
                                {
                                    <div class="gear-slot">
                                        <div class="gear-icon">
                                            <span class="glyph">@SlotGlyph(piece.Slot)</span>
                                            @if (piece.ItemLevel > 0)
                                            {
                                                <span class="ilvl-tag">i@(piece.ItemLevel)</span>
                                            }
                                        </div>
                                        <div class="gear-meta">
                                            <div class="gear-slot-name">@piece.Slot.ToUpper()</div>
                                            <div class="gear-item-name @(piece.IsHighQuality ? "hq" : "")">
                                                @(string.IsNullOrEmpty(piece.Name) ? "—" : piece.Name)
                                            </div>
                                            <div class="materia-dots">
                                                @foreach (var m in piece.Materia ?? new List<ExportMateriaV1>())
                                                {
                                                    <span class="mat-dot @MateriaStatClass(m.StatName)"
                                                          title="@m.StatName +@m.StatValue (slot @m.SlotIndex)"></span>
                                                }
                                                @for (int i = (piece.Materia?.Count ?? 0); i < piece.MateriaSlotCount; i++)
                                                {
                                                    <span class="mat-dot empty rec" title="empty (recommended fill)"></span>
                                                }
                                            </div>
                                            <div class="mobile-only" style="font-family: var(--f-mono); font-size: 10px; color: var(--frost-dim); margin-top: 4px; line-height: 1.4;">
                                                @foreach (var m in piece.Materia ?? new List<ExportMateriaV1>())
                                                {
                                                    <div>@m.StatName +@m.StatValue</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 16px; border-top:1px dashed var(--bd-pixel-lite); font-family:var(--f-mono); font-size:11px; color:var(--frost-dim);">
                                <span>Hover a slot to inspect</span>
                                <span>
                                    <span class="pill ship" style="margin-right:6px">melded · @TotalMateriaCount()</span>
                                    <span class="pill warn">empty · @(Optimization?.PlanRecommendations.Count ?? 0)</span>
                                </span>
                            </div>
                        }
                        else
                        {
                            <div style="padding:32px 24px; text-align:center; font-family:var(--f-serif); font-style:italic; color:var(--frost-dim); font-size:14px;">
                                The lantern waits. Paste your gear export above to fill this grid.
                            </div>
                        }
                    </div>
                </div>

                @* STAT PROFILE *@
                <div class="menu">
                    <div class="menu-head">
                        <span class="glyph">◇</span>
                        <span>Stat Profile</span>
                        <span class="spacer"></span>
                        <span class="pill gold">@StatProfileBadge()</span>
                    </div>
                    <div class="menu-body">
                        <div class="stat-grid">
                            @foreach (var s in BuildStatCells())
                            {
                                <div class="stat-cell">
                                    <div class="stat-name">@s.Name</div>
                                    <div class="stat-val">@s.Value</div>
                                    <div class="stat-deriv">
                                        <span><b>—</b> v0.6.1+</span>
                                    </div>
                                    <div class="stat-cap-bar">
                                        <div class="fill" style="width:@(s.PercentOfCap)%"></div>
                                    </div>
                                    <div class="cap-line">
                                        <span>+@s.MateriaTotal materia</span>
                                        <span></span>
                                    </div>
                                </div>
                            }
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 4px 2px; font-family:var(--f-mono); font-size:11px; color:var(--frost-dim); flex-wrap:wrap; gap:10px;">
                            <span>
                                <span style="display:inline-block; width:8px; height:8px; background:var(--lantern); box-shadow:0 0 6px var(--lantern); margin-right:6px; vertical-align:middle;"></span>
                                Materia totals from <code class="inline">/ttexport</code>
                            </span>
                            <span style="font-style:italic;">Derivation rows + breakpoint markers ship in v0.6.1 (Akhmorning formulas)</span>
                        </div>
                    </div>
                </div>

                @* MATERIA ADVISOR *@
                <div class="menu-warm">
                    <div class="menu-head">
                        <span class="glyph">◆</span>
                        <span>Materia Advisor</span>
                        <span class="spacer"></span>
                        @if (Optimization?.PlanRecommendations is { Count: > 0 } recs)
                        {
                            <span class="pill gold">@recs.Count melds queued</span>
                        }
                        <span class="badge">Job Priority (via Core)</span>
                    </div>
                    <div class="menu-body">
                        @if (Optimization?.PlanRecommendations is { Count: > 0 } recsList)
                        {
                            <div class="advisor-list" style="margin:-14px -16px 0;">
                                @{ int idx = 1; }
                                @foreach (var rec in recsList)
                                {
                                    <div class="advisor-rec">
                                        <span class="num">@CircledNum(idx)</span>
                                        <span class="knife">◆</span>
                                        <div class="desc">
                                            <span class="target">@rec.Piece · slot @(rec.SlotIndex + 1)</span>
                                            <span class="arrow"> → </span>
                                            <span class="change">
                                                <span class="out" style="font-style:italic;">(empty)</span>
                                                <span style="color:var(--frost-faint)">›</span>
                                                <span class="in">@rec.Materia.Display()</span>
                                            </span>
                                            <span class="pill warn">empty slot</span>
                                            <span class="why">
                                                Empty guaranteed slot — fill with @rec.Materia.Stat priority (+@rec.Materia.Value @rec.Materia.Stat)
                                            </span>
                                        </div>
                                        <div class="gain">
                                            +@rec.Materia.Value
                                            <span style="font-family:var(--f-pixel); font-size:7px; letter-spacing:1.5px; color:var(--frost-dim); margin-left:6px; vertical-align:middle;">@rec.Materia.Stat</span>
                                        </div>
                                    </div>
                                    idx++;
                                }
                                <div class="advisor-meta">
                                    <span>
                                        <span class="mode-tag">Mode · Job Priority (via Core)</span>
                                        <span style="margin-left:10px; font-style:italic;">
                                            applied via <code class="inline">MeldOptimizerAdapter</code> + <code class="inline">GearGoblin.Core</code>
                                            @if (ParsedPayload?.Character?.JobAbbreviation is { Length: > 0 } jab
                                                 && GearGoblin.Core.JobPriorities.IsTableHit(jab))
                                            {
                                                <span style="color:var(--ship-bright); margin-left:8px;">
                                                    · real @jab priority from thebalanceffxiv.com
                                                </span>
                                            }
                                            else if (ParsedPayload?.Character?.JobAbbreviation is { Length: > 0 } jab2)
                                            {
                                                <span style="color:var(--warning); margin-left:8px;">
                                                    · falling back to GNB tank baseline (Core has no table for @jab2)
                                                </span>
                                            }
                                        </span>
                                    </span>
                                    <span style="color:var(--ship-bright)">
                                        <span style="font-family:var(--f-pixel); font-size:7px; letter-spacing:2px; color:var(--frost-dim); margin-right:8px;">EMPTY</span>
                                        @recsList.Count slots
                                    </span>
                                </div>
                            </div>
                        }
                        else if (ParsedPayload != null)
                        {
                            <div style="padding:24px 16px; text-align:center; font-family:var(--f-serif); font-style:italic; color:var(--frost-soft); font-size:14px;">
                                All guaranteed slots filled. The knife is sharp.
                            </div>
                        }
                        else
                        {
                            <div style="padding:24px 16px; text-align:center; font-family:var(--f-serif); font-style:italic; color:var(--frost-dim); font-size:14px;">
                                Paste an export and STEP FORWARD to summon recommendations.
                            </div>
                        }
                    </div>
                </div>

                @* MELD AUDIT *@
                <div class="menu">
                    <div class="menu-head">
                        <span class="glyph">◇</span>
                        <span>Meld Audit</span>
                        <span class="spacer"></span>
                        <span class="badge">v0.6.6.0 derive</span>
                    </div>
                    <div class="menu-body">
                        <div class="audit" style="margin:-14px -16px 0;">
                            <div class="audit-cell">
                                <span class="pip @AuditPipClass(AuditEmptyCount())"></span>
                                <span class="audit-label">Empty slots</span>
                                <span class="audit-text">
                                    @if (AuditEmptyCount() > 0)
                                    {
                                        <text>@AuditEmptyCount() guaranteed slot(s) unmelded — fill all via STEP FORWARD</text>
                                    }
                                    else if (ParsedPayload != null)
                                    {
                                        <text>All guaranteed slots filled</text>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </span>
                                <span class="audit-count @AuditPipClass(AuditEmptyCount())">@AuditEmptyCount()</span>
                            </div>
                            <div class="audit-cell">
                                <span class="pip @AuditPipClass(AuditWrongStatCount())"></span>
                                <span class="audit-label">Wrong stat</span>
                                <span class="audit-text">
                                    @if (AuditWrongStatCount() > 0)
                                    {
                                        <text>@AuditWrongStatCount() meld(s) on stats outside @JobAbbr() priority</text>
                                    }
                                    else if (ParsedPayload != null)
                                    {
                                        <text>All melds on priority stats</text>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </span>
                                <span class="audit-count @AuditPipClass(AuditWrongStatCount())">@AuditWrongStatCount()</span>
                            </div>
                            <div class="audit-cell">
                                <span class="pip @AuditPipClass(AuditUnderTierCount())"></span>
                                <span class="audit-label">Under-tier</span>
                                <span class="audit-text">
                                    @if (AuditUnderTierCount() > 0)
                                    {
                                        <text>@AuditUnderTierCount() meld(s) below Tier XII — upgrade for +stat</text>
                                    }
                                    else if (ParsedPayload != null)
                                    {
                                        <text>All melds at current cap tier</text>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </span>
                                <span class="audit-count @AuditPipClass(AuditUnderTierCount())">@AuditUnderTierCount()</span>
                            </div>
                            <div class="audit-cell">
                                <span class="pip @AuditPipClass(AuditOvercapCount())"></span>
                                <span class="audit-label">Overcap</span>
                                <span class="audit-text">
                                    @if (AuditOvercapCount() > 0)
                                    {
                                        <text>@AuditOvercapCount() piece(s) with 2+ same-stat Tier XII (likely overcapping)</text>
                                    }
                                    else if (ParsedPayload != null)
                                    {
                                        <text>No likely overcap pieces detected</text>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </span>
                                <span class="audit-count @AuditPipClass(AuditOvercapCount())">@AuditOvercapCount()</span>
                            </div>
                            <div class="audit-cell" style="border-top:1px solid var(--border); margin-top:4px; padding-top:10px;">
                                <span class="pip @AuditPipClass(AuditReplaceCount())"></span>
                                <span class="audit-label">Sell / replace</span>
                                <span class="audit-text">
                                    @if (AuditReplaceCount() > 0)
                                    {
                                        <text>@AuditReplaceCount() materia recommended to extract & replace —</text>
                                        <button type="button" @onclick="ToggleSellBreakdown"
                                                style="background:none; border:none; color:var(--ship-bright); cursor:pointer; padding:0 0 0 6px; font-family:inherit; font-size:inherit; text-decoration:underline;">
                                            @(ShowSellBreakdown ? "hide" : "show") breakdown
                                        </button>
                                    }
                                    else if (ParsedPayload != null)
                                    {
                                        <text>All melded materia recommended to keep</text>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </span>
                                <span class="audit-count @AuditPipClass(AuditReplaceCount())">@AuditReplaceCount()</span>
                            </div>
                            @if (ShowSellBreakdown && BuildSellBreakdown() is { Count: > 0 } breakdown)
                            {
                                <div style="grid-column: 1 / -1; padding:6px 4px 10px; font-family:var(--f-mono); font-size:11px; color:var(--frost); display:flex; flex-direction:column; gap:6px;">
                                    @foreach (var v in breakdown)
                                    {
                                        <div style="display:flex; flex-wrap:wrap; gap:8px; padding:4px 8px; background:var(--bg-2); border-left:2px solid var(--lantern);">
                                            <span style="color:var(--lantern-dim); min-width:140px;">@v.Piece · slot @(v.SlotIndex + 1)</span>
                                            <span style="color:var(--frost-dim);">@v.CurrentMateriaName</span>
                                            <span style="color:var(--warning); flex:1;">@v.Headline</span>
                                            <span style="color:var(--ship-bright);">@v.Detail</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div style="padding:12px 4px 2px; display:flex; justify-content:space-between; font-family:var(--f-mono); font-size:11px; color:var(--frost-dim); flex-wrap:wrap; gap:8px;">
                            <span>
                                Severity:
                                <span style="color:var(--ship-bright)">● OK</span> ·
                                <span style="color:var(--lantern)">● Warn</span> ·
                                <span style="color:var(--blood-bright)">● Error</span>
                            </span>
                            <span>Audit logic mirrors plugin's MeldAudit format (v0.6.6.0)</span>
                        </div>
                    </div>
                </div>

            </div>
        </main>

        @* ─── RIGHT — OPTIMIZER / EXPORT / PLUGIN / FEEDBACK / MANIFESTO ─ *@
        <aside id="optimizer">
            <div class="stack-loose">

                @* OPTIMIZER CONTROLS *@
                <div class="menu">
                    <div class="menu-head">
                        <span class="glyph">◇</span>
                        <span>Optimizer</span>
                        <span class="spacer"></span>
                        <span class="badge">config</span>
                    </div>
                    <div class="menu-body">
                        <div style="margin-bottom:16px;">
                            <div class="h-eyebrow" style="margin-bottom:6px;">▸ Mode</div>
                            <div class="seg-toggle">
                                <button class="@(OptimizerMode == "Pure-Math" ? "on" : "")"
                                        @onclick='() => OptimizerMode = "Pure-Math"'>Pure Math</button>
                                <button class="@(OptimizerMode == "Balance" ? "on" : "")"
                                        @onclick='() => OptimizerMode = "Balance"'>Balance</button>
                            </div>
                            <div style="margin-top:8px; font-family:var(--f-serif); font-style:italic; font-size:12px; color:var(--frost-dim); line-height:1.5;">
                                @if (OptimizerMode == "Pure-Math")
                                {
                                    <text>Greedy per-stat priority — </text>
