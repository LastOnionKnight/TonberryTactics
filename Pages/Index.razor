    private static readonly string[] FeedbackCategories =
        { "Bug / glitch", "Optimizer disagreement", "Confusion / unclear", "Just saying hi" };
    private static readonly string[] FeedbackLabels =
        { "bug", "optimizer", "ux", "feedback" };

    private int    FeedbackCategory    = 0;
    private string FeedbackText        = string.Empty;
    private bool   FeedbackIncludeDiag = true;
    private string FeedbackLastAction  = string.Empty;

    private bool HasFeedbackText => !string.IsNullOrWhiteSpace(FeedbackText);

    private async Task OpenGitHubIssue()
    {
        if (!HasFeedbackText) return;
        try
        {
            var url = await BuildGitHubIssueUrlAsync();
            await JS.InvokeVoidAsync("window.open", url, "_blank", "noopener");
            FeedbackLastAction =
                $"✓ Opened GitHub issue in a new tab at {DateTime.Now:HH:mm:ss}. Edit and submit there.";
            FeedbackText = string.Empty;
        }
        catch (Exception ex)
        {
            FeedbackLastAction =
                $"Couldn't open browser tab ({ex.GetType().Name}). Try the Copy button instead.";
        }
    }

    private async Task CopyFeedbackPayload()
    {
        if (!HasFeedbackText) return;
        try
        {
            var payload = await BuildFeedbackPayloadAsync();
            await JS.InvokeVoidAsync(
                "navigator.clipboard.writeText", payload);
            FeedbackLastAction =
                $"✓ Copied to clipboard at {DateTime.Now:HH:mm:ss}. Paste in the FC Discord or DM Refia.";
            FeedbackText = string.Empty;
        }
        catch
        {
            FeedbackLastAction =
                "Couldn't access clipboard — browser may have blocked it. Try the GitHub button.";
        }
    }

    private async Task<string> BuildGitHubIssueUrlAsync()
    {
        var category = FeedbackCategories[FeedbackCategory];
        var label    = FeedbackLabels[FeedbackCategory];
        var title    = $"[v{TtVersion}] [{category}] ";
        var body     = await BuildFeedbackPayloadAsync();

        var titleEnc = Uri.EscapeDataString(title);
        var bodyEnc  = Uri.EscapeDataString(body);
        var labelEnc = Uri.EscapeDataString(label);

        return $"{FeedbackRepoUrl}/issues/new" +
               $"?title={titleEnc}&body={bodyEnc}&labels={labelEnc}";
    }

    private async Task<string> BuildFeedbackPayloadAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("### Category");
        sb.AppendLine(FeedbackCategories[FeedbackCategory]);
        sb.AppendLine();
        sb.AppendLine("### Message");
        sb.AppendLine(FeedbackText.Trim());
        sb.AppendLine();
        if (FeedbackIncludeDiag)
        {
            sb.AppendLine("### Diagnostic info");
            sb.AppendLine("```");
            sb.AppendLine($"TT version:        {TtVersion}");

            string userAgent = "(unavailable)";
            try
            {
                userAgent = await JS.InvokeAsync<string>(
                    "eval", "navigator.userAgent");
            }
            catch { /* swallow */ }
            sb.AppendLine($"User agent:        {userAgent}");

            sb.AppendLine($"Has export loaded: {!string.IsNullOrWhiteSpace(ExportString)}");
            sb.AppendLine($"Active job:        {(ParsedPayload?.Character?.JobAbbreviation ?? "(none)")}");
            sb.AppendLine($"Optimizer ran:     {Optimization != null}");
            sb.AppendLine($"Plan emitted:      {!string.IsNullOrEmpty(GeneratedImportString)}");
            sb.AppendLine($"Generated at:      {DateTime.UtcNow:o}");
            sb.AppendLine("```");
        }
        return sb.ToString();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
