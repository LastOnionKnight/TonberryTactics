@page "/"
@using TonberryTactics.Models
@using TonberryTactics.Services
@using System.Linq
@inject IJSRuntime JS

<HeadContent>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=JetBrains+Mono:wght@400;600&family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/design-phase2.css">
</HeadContent>

<!-- ─── MASTHEAD ────────────────────────────────────────────────────────── -->
<header class="masthead">
  <img class="mh-bg" src="assets/masthead.png" alt="Tonberry Tactics" />
</header>
<div class="subbar">
  <div class="wrap subbar-inner">
    <span class="tagline">"No gear. No hope. No pants. Just onions."</span>
    <div class="subbar-meta">
      <span class="chip gold">v 1.5.0</span>
      <span class="sub-plugin">paired with plugin v0.6.0+</span>
      <span class="sub-div">TLF · Gear Division</span>
      <span class="patch-pill">◆ Evercold · Patch 7.5</span>
      <button class="btn ghost" onclick="window.setTheme(window.getTheme() === 'dark' ? 'light' : 'dark')" title="Toggle Theme" style="padding:4px 8px; border:1px solid var(--line); border-radius:4px; background:var(--sink); cursor:pointer;">
        <img src="assets/tt-lantern-mark.svg" style="height:14px; opacity:0.8;" alt="Theme Toggle"/>
      </button>
    </div>
  </div>
</div>

<!-- ─── HERO — live close-the-gap demo ──────────────────────────────────── -->
<section class="hero-demo">
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">The close-the-gap moment</span>
      <h1 class="hero-head">Know exactly how far<br />you are from <span class="accent">cap</span>.</h1>
      <p class="hero-sub">Every substat has a ceiling. Tonberry Tactics reads your real totals straight from the game and shows the melds that close the distance — watch it work before you read a word.</p>
      <div class="hero-cta">
        <a class="btn primary" href="#exportTop">▶ Paste your gear</a>
        <button class="btn ghost cobalt" id="heroReplay" onclick="playHero()">↺ Replay</button>
      </div>
    </div>
    <div class="hero-stage">
      <div class="hero-gauges" id="heroGauges"></div>
      <div class="hero-legend">
        <span><i class="dot gold"></i> Current</span>
        <span><i class="dot cobalt"></i> Near cap</span>
        <span><i class="dot ghost"></i> After optimization</span>
      </div>
    </div>
  </div>
</section>

<div class="wrap">

  <!-- ─── EXPORT BAR ────────────────────────────────────────────────────── -->
  <section class="panel export-bar" id="exportTop">
    <div class="panel-hd"><span class="title">Adventurer</span><span class="chip">/ttexport → audit</span></div>
    <div class="panel-bd">
      <p class="export-lead"><span class="italic">Step forward.</span> Paste the <span class="tok">GG-EXPORT:v1:</span> string from <span class="cmd">/ttexport</span> to begin the audit.</p>
      <div class="export-row">
        <textarea id="exportInput" placeholder="GG-EXPORT:v1:eyJwbHVnaW4iOiJUb25iZXJyeVRhY3RpY3MiLi4u" @bind="ExportString" @bind:event="oninput"></textarea>
        <button class="step-forward" id="stepBtn" @onclick="RunOptimization">
          ▶ Step Forward
          <small>— star once, star true —</small>
        </button>
      </div>
      <div style="margin-top:10px; display:flex; gap:10px; align-items:center; flex-wrap:wrap; font-family:var(--f-data); font-size:11px; color:var(--fg-muted);">
          @if (ParsedPayload != null)
          {
              <span class="chip gold">
                  parsed · @ParsedPayload.Character.JobAbbreviation ·
                  iLvl @ParsedPayload.Character.AverageItemLevel ·
                  @ParsedPayload.Equipped.Count pieces ·
                  @TotalMateriaCount() melds
              </span>
          }
          else if (!string.IsNullOrWhiteSpace(ParseError))
          {
              <span class="chip" style="color:var(--err); border-color:var(--err);">parse failed</span>
          }
          else
          {
              <span class="chip">awaiting export</span>
          }
      </div>
      @if (!string.IsNullOrWhiteSpace(ParseError))
      {
          <div style="margin-top:10px; padding:10px 12px; border:1px solid var(--err); background:rgba(192,85,107,0.05); font-family:var(--f-data); font-size:12px; color:var(--err);">
              @ParseError
          </div>
      }
      <div class="export-actions">
        <button class="btn ghost cobalt" id="sampleBtn" onclick="loadSample()">Load sample export</button>
        <button class="btn ghost" id="clearBtn" @onclick="ClearPlan">Clear</button>
      </div>
    </div>
  </section>

  <!-- ─── MAIN LAYOUT ───────────────────────────────────────────────────── -->
  <div class="layout">

    <!-- LEFT: ADVENTURER -->
    <aside class="col-left">
      <section class="panel">
        <div class="panel-hd"><span class="title">Adventurer</span><span class="chip" id="advTag">@(ParsedPayload != null ? "linked" : "unlinked")</span></div>
        <div class="panel-bd">
          <img class="adv-portrait" src="assets/adventurer.png" alt="Adventurer portrait" />
          <div class="adv-name" id="advName">@AdvDisplayName()</div>
          <div class="adv-role">Onion Knight of the TLF</div>
          <div class="adv-stats">
            <div class="row"><span class="k">Job</span><span class="v @(ParsedPayload==null?"dim":"")" id="advJob">@AdvJob()</span></div>
            <div class="row"><span class="k">Level</span><span class="v @(ParsedPayload==null?"dim":"")" id="advLevel">@AdvLevel()</span></div>
            <div class="row"><span class="k">Avg iLvl</span><span class="v @(ParsedPayload==null?"dim":"")" id="advIlvl">@AdvIlvl()</span></div>
            <div class="row"><span class="k">Melds</span><span class="v @(ParsedPayload==null?"dim":"")" id="advMelds">
                @if (Optimization != null)
                {
                    <span style="color:var(--ok)">+@TotalMateriaCount() queued</span>
                }
                else
                {
                    <text>—</text>
                }
            </span></div>
            <div class="row"><span class="k">Status</span><span class="adv-status" id="advStatus" style="@(ParsedPayload!=null ? "color:var(--ok); border-color:rgba(58,157,110,0.4);" : "")">
                @(ParsedPayload!=null ? "audited" : "awaiting gear")
            </span></div>
          </div>
          <div class="adv-credo">
            "Star once, star true. The lantern guides, the knife decides."
            <span class="sig">— TLF Credo —</span>
          </div>
        </div>
      </section>
    </aside>

    <!-- MIDDLE: GEARSET / STAT PROFILE / ADVISOR / AUDIT -->
    <section class="col-mid">

      <section class="panel">
        <div class="panel-hd"><span class="title">Gearset</span><span class="chip" id="gearCount">@GearSlotCount() / 13</span></div>
        <div class="panel-bd">
          @if (ParsedPayload?.Equipped is { Count: > 0 } pieces)
          {
              <div id="gearGrid" class="gear-grid">
                  @foreach (var piece in pieces)
                  {
                      <div class="gear-slot">
                          <div class="g-top">
                              <span class="g-name">@(string.IsNullOrEmpty(piece.Name) ? piece.Slot.ToUpper() : piece.Name)</span>
                              <span class="g-ilvl">i@(piece.ItemLevel)</span>
                          </div>
                          <div class="g-sub">
                              <span class="g-slot">@piece.Slot</span>
                              <div class="g-melds">
                                  @if (piece.Materia is { Count: > 0 })
                                  {
                                      @foreach (var m in piece.Materia)
                                      {
                                          var code = MateriaIcon(m.StatName);
                                          <img class="materia-orb" src="assets/materia/@(code).png" onerror="this.onerror=null;this.src='assets/materia/@(code).svg'" alt="@m.StatName" title="@m.StatName" />
                                      }
                                  }
                                  else
                                  {
                                      <span class="g-nomeld">no melds</span>
                                  }
                              </div>
                          </div>
                      </div>
                  }
              </div>
              <div class="materia-key" id="materiaKey">
                  <span class="mk-label">Materia</span>
                  @foreach (var (stat, code) in MateriaCodes)
                  {
                      <span class="mk-item">
                          <img class="materia-orb" src="assets/materia/@(code).png" onerror="this.onerror=null;this.src='assets/materia/@(code).svg'" alt="@stat" title="@stat" />
                          @stat.ToUpper()
                      </span>
                  }
              </div>
          }
          else
          {
              <div id="gearEmpty" class="empty-state">The lantern waits. Paste your gear export above to fill this grid.</div>
          }
        </div>
      </section>

      <section class="panel">
        <div class="panel-hd"><span class="title">Stat Profile</span><span class="chip cobalt">substats vs cap</span></div>
        <div class="panel-bd">
          <div id="statGrid" class="stat-grid">
              @if (ParsedPayload?.Character.TotalStats != null && ParsedPayload.Character.TotalStats.Count > 0)
              {
                  @foreach (var s in ParsedPayload.Character.TotalStats)
                  {
                      <CapGauge Label="@s.DisplayName" Value="@s.Value" Cap="@s.Cap" />
                  }
              }
              else
              {
                  <div class="empty-state">Real caps require a v2 export from GearGoblin 0.6.0+.</div>
              }
          </div>
          <div class="stat-note"><span class="dot">●</span> <span>Materia totals from <strong>/ttexport</strong>. Derivation rows + breakpoint markers ship in v0.6.1 (Akhmorning formulas).</span></div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-hd"><span class="title">Materia Advisor</span><span class="chip" id="advisorChip">job priority order</span></div>
        <div class="panel-bd">
          @if (Optimization?.PlanRecommendations is { Count: > 0 } recsList)
          {
              <div id="advisorList">
                  @{ int idx = 1; }
                  @foreach (var rec in recsList)
                  {
                      var code = MateriaIcon(rec.Materia.Stat.ToString());
                      <div class="advisor-row">
                          <span class="ad-rank">@RomanGrade(idx)</span>
                          <img class="materia-orb ad-orb" src="assets/materia/@(code).png" onerror="this.onerror=null;this.src='assets/materia/@(code).svg'" alt="@rec.Materia.Stat.ToString()" title="@rec.Materia.Stat.ToString()" />
                          <span class="ad-text">
                              @rec.Piece #@(rec.SlotIndex + 1) ← @rec.Materia.Display()
                              <span class="ad-gain">(+@rec.Materia.Value)</span>
                          </span>
                          <span class="chip cobalt">empty slot</span>
                      </div>
                      idx++;
                  }
              </div>
          }
          else if (ParsedPayload != null)
          {
              <div class="empty-state">All guaranteed slots filled. The knife is sharp.</div>
          }
          else
          {
              <div id="advisorEmpty" class="empty-state">Paste an export and step forward to summon recommendations.</div>
          }
        </div>
      </section>

      <section class="panel">
        <div class="panel-hd"><span class="title">Meld Audit</span><span class="chip">MeldAudit · v0.6.6.0</span></div>
        <div class="panel-bd">
          <div class="audit-grid">
            <div class="audit-row @AuditPipClass(AuditEmptyCount())"><span class="sev"></span><span class="a-name">Empty slots</span><span class="a-val">@(ParsedPayload != null ? AuditEmptyCount() : "—")</span></div>
            <div class="audit-row @AuditPipClass(AuditWrongStatCount())"><span class="sev"></span><span class="a-name">Wrong stat</span><span class="a-val">@(ParsedPayload != null ? AuditWrongStatCount() : "—")</span></div>
            <div class="audit-row @AuditPipClass(AuditUnderTierCount())"><span class="sev"></span><span class="a-name">Under-tier</span><span class="a-val">@(ParsedPayload != null ? AuditUnderTierCount() : "—")</span></div>
            <div class="audit-row @AuditPipClass(AuditOvercapCount())"><span class="sev"></span><span class="a-name">Overcap</span><span class="a-val">@(ParsedPayload != null ? AuditOvercapCount() : "—")</span></div>
            <div class="audit-row @AuditPipClass(AuditReplaceCount())"><span class="sev"></span><span class="a-name">Sell / replace</span><span class="a-val">
                @(ParsedPayload != null ? AuditReplaceCount() : "—")
                @if (AuditReplaceCount() > 0)
                {
                    <button type="button" @onclick="ToggleSellBreakdown" style="background:none; border:none; color:var(--cobalt-bright); cursor:pointer; padding:0 0 0 6px; font-family:inherit; font-size:inherit; text-decoration:underline;">
                        @(ShowSellBreakdown ? "hide" : "show")
                    </button>
                }
            </span></div>
          </div>
          @if (ShowSellBreakdown && BuildSellBreakdown() is { Count: > 0 } breakdown)
          {
              <div style="margin-top:10px; font-family:var(--f-data); font-size:11px; color:var(--fg); display:flex; flex-direction:column; gap:6px;">
                  @foreach (var v in breakdown)
                  {
                      <div style="display:flex; flex-wrap:wrap; gap:8px; padding:6px 10px; background:var(--sink); border-left:2px solid var(--warn); border-radius:4px;">
                          <span style="color:var(--fg-2); min-width:140px;">@v.Piece · slot @(v.SlotIndex + 1)</span>
                          <span style="color:var(--fg-muted);">@v.CurrentMateriaName</span>
                          <span style="color:var(--warn); flex:1;">@v.Headline</span>
                          <span style="color:var(--ok);">@v.Detail</span>
                      </div>
                  }
              </div>
          }
          <div class="audit-legend">
            <span>Severity:</span>
            <span class="sw"><i style="background:var(--ok)"></i> OK</span>
            <span class="sw"><i style="background:var(--warn)"></i> Warn</span>
            <span class="sw"><i style="background:var(--over)"></i> Error</span>
            <span style="margin-left:auto; font-style:italic;">Mirrors plugin's MeldAudit format</span>
          </div>
        </div>
      </section>

    </section>

    <!-- RIGHT: OPTIMIZER / EXPORT / PSA / FEEDBACK / MANIFESTO -->
    <aside class="col-right">

      <section class="panel">
        <div class="panel-hd"><span class="title">Optimizer</span><span class="chip">config</span></div>
        <div class="panel-bd">
          <div class="job-label">Mode</div>
          <div class="mode-toggle" id="modeToggle">
            <button class="@(OptimizerMode == "Pure-Math" ? "active" : "")" @onclick='() => OptimizerMode = "Pure-Math"'>Pure Math</button>
            <button class="@(OptimizerMode == "Balance" ? "active" : "")" @onclick='() => OptimizerMode = "Balance"'>Balance</button>
          </div>
          <p class="mode-desc" id="modeDesc">
              @if (OptimizerMode == "Pure-Math")
              {
                  <text><b>Greedy per-stat priority</b> — fast, naive, ships today.</text>
              }
              else
              {
                  <text><b>Balance consensus weights</b> — queued for v0.6.1+.</text>
              }
          </p>
          <div class="job-label">Job profile</div>
          <div class="job-grid" id="jobGrid">
              @foreach (var (abbr, role) in AllJobs)
              {
                  var jobColor = JobColors.TryGetValue(abbr, out var c) ? c : "#8a93a0";
                  <button class="job @role @(ActiveJob() == abbr ? "active" : "")" 
                          style="--jc: @jobColor"
                          @onclick="@(() => ActiveJobOverride = abbr)">
                      <img class="jobstone" src="assets/jobs/@(abbr).png" alt="@abbr" />
                      <span class="job-abbr">@abbr</span>
                  </button>
              }
          </div>
          <div class="job-legend">
            <span><i style="background:var(--cobalt)"></i> Tank</span>
            <span><i style="background:var(--ok)"></i> Healer</span>
            <span><i style="background:var(--gold)"></i> DPS</span>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-hd"><span class="title">Export to Game</span><span class="chip gold">GG-PLAN:v1:</span></div>
        <div class="panel-bd">
          <p class="mode-desc">Copy and paste into <b>/ttimport</b> back in-game.</p>
          <textarea id="planOutput" placeholder="Plan string appears after STEP FORWARD." readonly style="min-height:74px;" value="@GeneratedImportString"></textarea>
          <div class="fb-actions" style="margin-top:10px; flex-direction:row; gap:8px;">
            <button class="btn full" id="copyPlan" @onclick="CopyImportString" disabled="@(string.IsNullOrEmpty(GeneratedImportString))">◆ Copy plan</button>
            <button class="btn full ghost" id="roundTrip">↺ Round-trip ready</button>
          </div>
        </div>
      </section>

      <section class="panel psa">
        <div class="panel-hd"><span class="title">TLF Home for Children Without Knives</span></div>
        <div class="panel-bd">
          <div class="psa-emblem-wrap"><img class="psa-emblem" src="assets/tlf-flame-logo-768.png" alt="Tonberry Liberation Front" /></div>
          <div class="video-thumb">
            <img class="vt-sprite" src="assets/rags-action.png" alt="" />
            <span class="v-cap">TLF Home For Children</span>
            <span class="v-sub">Refia Rakkiri · Last Onion Knight</span>
            <span class="play"></span>
          </div>
          <div class="psa-text">
            <p>A public service announcement from the Tonberry Liberation Front. Somewhere in the dark, a Tonberry youngling sits with empty hands and a cold lantern — unable to chop, unable to whittle, unable to say "Stab" with any conviction at all.</p>
            <p>We provide safe underground housing, cultural education, and access to age-appropriate knives. For less than ye'd waste on a single sad teleport, you can restore what was taken.</p>
            <p>Oi'm not askin' for meself. Oi'm askin' for <em>them</em>.</p>
            <div class="donate">
                <a class="btn" href="https://newageninjacorps.com/collections/tonberry-liberation-front" target="_blank" rel="noopener noreferrer" style="text-decoration:none;">🔪 Donate a knife</a>
            </div>
            <p class="small">Comment "Onion of us." It's not a cult. Probably. The sœnnagins are watching.</p>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-hd"><span class="title">Feedback</span><span class="chip">v1.5.0</span></div>
        <div class="panel-bd">
          <p class="mode-desc">Bug, disagreement, confusion, or just saying hi — drop a line and I'll find Refia.</p>
          <div class="job-label">Category</div>
          <div class="fb-cat" id="fbCat">
              @for (int i = 0; i < FeedbackCategories.Length; i++)
              {
                  var ix = i;
                  <button class="@(FeedbackCategory == ix ? "active" : "")" @onclick="@(() => FeedbackCategory = ix)">@FeedbackCategories[ix]</button>
              }
          </div>
          <div class="job-label">Message</div>
          <textarea placeholder="What happened? What did you expect? What's auld the lantern on?" style="min-height:80px;" @bind="FeedbackText" @bind:event="oninput"></textarea>
          <label class="fb-check"><input type="checkbox" @bind="FeedbackIncludeDiag" /> Include diagnostic info (version, browser, parser state)</label>
          <div class="fb-actions" style="margin-top:10px;">
            <button class="btn full cobalt" @onclick="OpenGitHubIssue" disabled="@(!HasFeedbackText)">⎘ Open GitHub issue</button>
            <button class="btn full ghost" @onclick="CopyFeedbackPayload" disabled="@(!HasFeedbackText)">Copy for Discord</button>
          </div>
          @if (!string.IsNullOrEmpty(FeedbackLastAction))
          {
              <div style="margin-top:10px; font-family:var(--f-data); font-size:11px; color:var(--ok);">
                  @FeedbackLastAction
              </div>
          }
        </div>
      </section>

      <section class="panel manifesto">
        <div class="panel-hd"><span class="title">TLF Manifesto</span></div>
        <div class="panel-bd">
          <span class="line">We carry the lantern. We carry the knife.</span><br />
          We do not run. We step forward — star once, star true — and we close the gap, one meld at a time.
          <div class="m-chips">
            <span class="m-chip">Offline · fast</span>
            <span class="m-chip">No backend</span>
            <span class="m-chip cobalt">Round-trip · v1</span>
          </div>
        </div>
      </section>

    </aside>
  </div>
</div>

<footer class="site-foot">
  <div class="wrap">
    <div class="foot-parade">
      <div class="ground"></div>
      <div class="parade-line">
        @for(int p = 1; p <= 22; p++) {
          <div class="px"><img src="assets/jobs-px/@(p.ToString("D2")).png" alt="" /></div>
        }
      </div>
    </div>
    <img src="assets/tt-lantern-mark.svg" alt="TLF Emblem" class="foot-emblem" />
    <div class="foot-credo">◆ <img src="assets/tt-lantern-mark.svg" class="fc-mark" alt="mark"/> The Onion Knight stands ready <img src="assets/tt-lantern-mark.svg" class="fc-mark" alt="mark"/> ◆</div>
    <div class="foot-meta">Tonberry Tactics · v1.5.0 · Cloudflare Pages · No gear · No hope · Just onions</div>
  </div>
</footer>

<script>
  // ── HERO: live close-the-gap demo ─────────────────────────────────────────
  var HERO = [
    { label:'Critical Hit', value:2410, cap:2780, proj:2680 },
    { label:'Direct Hit',   value:1180, cap:2780, proj:1456 }
  ];
  function fmt(n){ return n.toLocaleString('en-US'); }
  var RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function buildHero(){
    var host=document.getElementById('heroGauges'); if(!host) return; host.innerHTML='';
    HERO.forEach(function(s){
      var fillPct=Math.round(s.value/s.cap*100), pPct=Math.round(s.proj/s.cap*100);
      var near=fillPct>=90;
      var gap=s.cap-s.value, closes=s.proj-s.value;
      var g=document.createElement('div'); g.className='hero-gauge';
      g.innerHTML='<div class="hg-head"><span class="hg-label">'+s.label+'</span>'+
        '<span class="hg-val"><span class="cur">'+fmt(s.value)+'</span> <span class="cap">/ '+fmt(s.cap)+' cap</span> <span class="proj">▸ '+fmt(s.proj)+'</span></span></div>'+
        '<div class="hero-track"><div class="hg-proj" data-fill="'+pPct+'"></div>'+
          '<div class="hg-fill'+(near?' is-near':'')+'" data-fill="'+fillPct+'"></div>'+
          '<div class="hero-tick"></div></div>'+
        '<div class="hg-gap">'+fmt(gap)+' to cap · <span class="closes">plan closes '+fmt(closes)+'</span></div>';
      host.appendChild(g);
    });
  }
  function playHero(){
    var host=document.getElementById('heroGauges'); if(!host) return;
    var fills=host.querySelectorAll('.hg-fill'), projs=host.querySelectorAll('.hg-proj');
    var head=document.querySelector('.hero-head');
    if(RM){
      fills.forEach(function(f){ f.style.width=f.dataset.fill+'%'; });
      projs.forEach(function(p){ p.style.width=p.dataset.fill+'%'; });
      if(head) head.classList.add('in'); host.classList.add('show-proj'); return;
    }
    fills.forEach(function(f){ f.style.width='0%'; });
    projs.forEach(function(p){ p.style.width='0%'; });
    if(head) head.classList.remove('in'); host.classList.remove('show-proj');
    requestAnimationFrame(function(){
      setTimeout(function(){ fills.forEach(function(f){ f.style.width=f.dataset.fill+'%'; }); }, 160);
      setTimeout(function(){ if(head) head.classList.add('in'); }, 720);
      setTimeout(function(){ projs.forEach(function(p){ p.style.width=p.dataset.fill+'%'; }); host.classList.add('show-proj'); }, 1750);
    });
  }
  function loadSample() {
      // Basic stub for the sample loader JS trigger; in Blazor this would update state,
      // but for now we just populate the textarea and click the step button
      document.getElementById('exportInput').value = 'GG-EXPORT:v2:';
      var evt = new Event('input', { bubbles: true });
      document.getElementById('exportInput').dispatchEvent(evt);
      setTimeout(function() { document.getElementById('stepBtn').click(); }, 50);
  }
  
  // init hero
  setTimeout(function() {
      buildHero(); playHero();
  }, 100);
</script>


